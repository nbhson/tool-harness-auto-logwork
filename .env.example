# ─── Server ──────────────────────────────────────────
HOST=127.0.0.1
PORT=8765
DEBUG=true

# ─── Database ────────────────────────────────────────
DATABASE_URL=sqlite:///./worklog.db

# ─── Jira (để trống nếu chưa dùng) ──────────────────
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT=PROJ
JIRA_POLL_INTERVAL_MINUTES=10

# ─── Bitbucket (để trống nếu chưa dùng) ─────────────
BITBUCKET_USERNAME=your-bitbucket-username
BITBUCKET_APP_PASSWORD=your-app-password
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_POLL_INTERVAL_MINUTES=10

# ─── GitHub Models ───────────────────────────────────
# Token để dùng GitHub Models API (https://github.com/marketplace/models)
# GITHUB_TOKEN=ghp_your-github-token
# GITHUB_BASE_URL=https://models.inference.ai.azure.com

# ─── Git hooks log file ──────────────────────────────
# File mà post-commit hook sẽ ghi vào (mặc định: ~/.worklog_git_hooks.jsonl)
# GIT_HOOK_LOG=~/.worklog_git_hooks.jsonl
